{
  "name": "smd",
  "version": "1.0.0",
  "description": "System Manager Detector",
  "main": "src/index.ts",
  "bin": {
    "smd": "./dist/smd.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "start": "bun run bin/smd.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "node scripts/build.js",
    "compile": "bun build --compile bin/smd.ts --outfile bin/smd",
    "compile:linux": "bun build --compile --target=bun-linux-x64 bin/smd.ts --outfile dist/smd-linux",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "bun-types": "^1.3.14",
    "esbuild": "^0.28.0",
    "pino-pretty": "^13.1.3",
    "typescript": "^6.0.3"
  }
}
